---
---
<section class="hero-section" id="contacto">
  <div class="hero-image-container">
    <img src="/assets/images/portada.webp" alt="Alumnos del Instituto Nikola Tesla" class="hero-img" />
  </div>
  
  <div class="hero-form-container">
    <div class="form-wrapper-desktop">
      <div id="form-header-block">
        <h2 class="hero-title"><span class="font-thin">¡Rellena el formulario y obtén</span> <span class="font-bold">una inscripción gratis!</span></h2>
      </div>
      
      <form class="tesla-form" id="tesla-leads-form">
        <input type="text" name="nombre" placeholder="Nombre completo" required />
        <input type="tel" name="telefono" placeholder="Teléfono / WhatsApp" required />
        
        <select name="motivo" required>
          <option value="" disabled selected>Motivo de contacto</option>
          <option value="primaria">Primaria</option>
          <option value="secundaria">Secundaria</option>
          <option value="preparatoria">Preparatoria</option>
          <option value="enfermeria">Universidad - Enfermería</option>
          <option value="medicina">Universidad - Médico Cirujano</option>
          <option value="pedagogia">Universidad - Pedagogía</option>
          <option value="derecho">Universidad - Derecho</option>
          <option value="maestria">Posgrado - Maestría en Educación</option>
          <option value="especialidad">Posgrado - Especialidad en Enfermería Quirúrgica</option>
          <option value="otros">Otros motivos</option>
        </select>

        <select name="campus" required>
          <option value="" disabled selected>¿Qué campus te interesa?</option>
          <option value="tehuantepec">Campus Tehuantepec</option>
          <option value="huatulco">Campus Huatulco (Solo Universidad)</option>
        </select>

        <input type="text" name="correo" placeholder="Correo electrónico (Opcional)" />
        
        <textarea name="mensaje" rows="3" placeholder="Déjanos un mensaje (Opcional)"></textarea>
        
        <button type="submit" class="btn-enviar" id="submit-btn">¡Enviar! 🚀</button>
      </form>

      <div id="success-block" class="success-message">
        <div class="success-icon">🎉💜</div>
        <h3>¡Registro Exitoso!</h3>
        <p>Hemos recibido tus datos correctamente en nuestro sistema escolar.</p>
        <p>Un asesor del <strong>Instituto Nikola Tesla</strong> se pondrá en contacto contigo lo más pronto posible para asegurar tu lugar e inscripción gratis. ¡Bienvenido!</p>
      </div>

    </div>
  </div>
</section>

<style>
  .hero-section {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 100vh;
    margin: 0;
    padding: 0; 
  }
  
  .hero-image-container {
    overflow: hidden;
    position: relative;
  }
  .hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  .hero-image-container:hover .hero-img {
    transform: scale(1.08);
  }
  
  .hero-form-container {
    background-color: var(--color-morado-2);
    color: var(--color-blanco);
    padding: 120px 40px 60px 40px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .form-wrapper-desktop {
    width: 100%;
    max-width: 580px; 
    margin: 0 auto;   
    padding-right: 15px; 
  }

  .hero-title {
    font-size: 2.4rem;
    margin-bottom: 30px;
    line-height: 1.25;
    text-align: left; 
    display: block; 
  }

  .font-thin { font-weight: 300; }
  .font-bold { font-weight: 700; }
  
  .tesla-form {
    display: flex;
    flex-direction: column;
    gap: 15px;
  }
  
  .tesla-form input, .tesla-form select, .tesla-form textarea {
    width: 100%;
    padding: 14px;
    border-radius: 8px;
    border: none;
    font-family: inherit;
    font-size: 1rem;
    background: rgba(255, 255, 255, 0.98);
    color: var(--color-negro);
  }

  .tesla-form input::placeholder, 
  .tesla-form textarea::placeholder {
    color: #555555 !important;
    opacity: 1;
  }

  .tesla-form select:invalid,
  .tesla-form select option[value=""] {
    color: #555555;
  }

  .tesla-form input:focus, .tesla-form select:focus, .tesla-form textarea:focus {
    outline: 2px solid var(--color-blanco);
  }
  
  .btn-enviar {
    background: var(--color-blanco);
    color: var(--color-morado-2);
    border: none;
    padding: 15px;
    border-radius: 50px;
    font-size: 1.1rem;
    font-weight: bold;
    cursor: pointer;
    transition: all 0.3s ease;
    margin-top: 10px;
  }
  .btn-enviar:hover {
    transform: translateY(-2px);
    box-shadow: 0 5px 15px rgba(0,0,0,0.2);
  }
  .btn-enviar:disabled {
    background-color: #cccccc;
    color: #666666;
    cursor: not-allowed;
    transform: none;
    box-shadow: none;
  }

  /* ESTILOS DEL MENSAJE DE ÉXITO */
  .success-message {
    display: none; 
    text-align: center;
    background: rgba(255, 255, 255, 0.1);
    border: 2px dashed rgba(255, 255, 255, 0.3);
    padding: 40px 30px;
    border-radius: 20px;
    animation: popIn 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }
  
  .success-icon {
    font-size: 4rem;
    margin-bottom: 20px;
  }

  .success-message h3 {
    font-size: 2.2rem;
    font-weight: 700;
    margin-bottom: 15px;
    color: var(--color-blanco);
  }

  .success-message p {
    font-size: 1.15rem;
    line-height: 1.6;
    margin-bottom: 15px;
    color: rgba(255, 255, 255, 0.95);
  }

  @keyframes popIn {
    0% { transform: scale(0.9); opacity: 0; }
    100% { transform: scale(1); opacity: 1; }
  }

  /* =========================================
     VERSION COLAPSADA (MÓVIL)
  ========================================= */
  @media (max-width: 900px) {
    .hero-section { grid-template-columns: 1fr; }
    .hero-image-container { height: 45vh; }
    .hero-form-container { 
      padding: 50px 20px; 
      align-items: center;
    }
    .form-wrapper-desktop {
      max-width: 100%;
      padding-right: 0;
    }
    .hero-title {
      text-align: center;
      font-size: 1.8rem;
    }
    .success-message h3 {
      font-size: 1.8rem;
    }
  }
</style>

<script>
  const form = document.getElementById('tesla-leads-form') as HTMLFormElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const headerBlock = document.getElementById('form-header-block');
  const successBlock = document.getElementById('success-block');
  const scriptURL = 'https://script.google.com/macros/s/AKfycbzVVKqpb8r-dzmGlMxsLGarYGLtLuyPu96WMAGOEqUoSCZxlppzWmRVFyV73o69NHE/exec';

  if (form && successBlock && headerBlock) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      
      submitBtn.disabled = true;
      submitBtn.innerText = 'Enviando... ⏳';

      const formData = new FormData(form);
      const ahora = new Date();
      const fechaHoraLocal = ahora.toLocaleString('es-MX', { timeZone: 'America/Mexico_City' });
      formData.append('fecha', fechaHoraLocal);

      fetch(scriptURL, { 
        method: 'POST', 
        body: formData,
        mode: 'no-cors'
      })
      .then(() => {
        // Ocultamos formulario y mostramos éxito
        headerBlock.style.display = 'none';
        form.style.display = 'none';
        successBlock.style.display = 'block';
        successBlock.scrollIntoView({ behavior: 'smooth', block: 'center' });

        // 🔥 DISPARO DEL PIXEL DE CONVERSIÓN (LEAD) 🔥
        // Validamos que 'fbq' exista por si el usuario usa un bloqueador de anuncios
        if (typeof fbq === 'function') {
          fbq('track', 'Lead');
        }
      })
      .catch(error => {
        console.error('Error al enviar los datos:', error);
        alert('Hubo un pequeño inconveniente técnico al procesar el envío. Por favor, intenta de nuevo.');
        submitBtn.disabled = false;
        submitBtn.innerText = '¡Enviar! 🚀';
      });
    });
  }
</script>