<style>
  .ubicaciones-section {
    /* Aquí agregamos la imagen de fondo */
    background-image: url('/assets/images/notebook.webp');
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    padding: 80px 20px;
  }
  
  .campus-grid {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 30px;
  }
  
  .campus-card {
    background: linear-gradient(to bottom, var(--color-morado-2), var(--color-morado));
    color: var(--color-blanco);
    border-radius: 20px;
    padding: 30px 20px;
    text-align: center;
    /* Sombra un poco más intensa para destacar sobre la textura */
    box-shadow: 0 15px 30px rgba(0,0,0,0.2);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  
  .campus-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 20px 40px rgba(0,0,0,0.3);
  }
  
  .icon-circle {
    font-size: 3rem;
    margin-bottom: 15px;
  }
  .campus-card h3 { margin-bottom: 15px; font-size: 1.4rem; }
  .campus-card p { margin-bottom: 25px; font-size: 0.95rem; line-height: 1.5; opacity: 0.9; }
  
  .card-actions {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  
  /* Botones minimalistas de borde blanco */
  .btn-contacto {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    background: transparent;
    color: var(--color-blanco);
    border: 1.5px solid var(--color-blanco);
    text-decoration: none;
    padding: 10px;
    border-radius: 50px;
    font-weight: bold;
    transition: all 0.2s ease;
  }
  
  .btn-contacto:hover {
    background: rgba(255, 255, 255, 0.1);
    transform: scale(1.02);
  }
</style>